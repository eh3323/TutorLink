generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String            @id @default(cuid())
  email                 String            @unique
  passwordHash          String?
  role                  String?
  isAdmin               Boolean           @default(false)
  isSuspended           Boolean           @default(false)
  verificationStatus    String            @default("UNVERIFIED")
  verificationNote      String?
  verificationSubmittedAt DateTime?
  verificationDocumentUrl  String?
  verificationDocumentName String?
  verificationDocumentType String?
  verificationDocumentSize Int?
  schoolEmailVerifiedAt DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  profile               Profile?
  tutorProfile          TutorProfile?
  tuteeProfile          TuteeProfile?
  tutoringRequests      TutoringRequest[]
  tutorThreads          MessageThread[]   @relation("TutorThreads")
  tuteeThreads          MessageThread[]   @relation("TuteeThreads")
  sentMessages          Message[]
  tutorSessions         Session[]           @relation("TutorSessions")
  tuteeSessions         Session[]           @relation("TuteeSessions")
  writtenReviews        Review[]            @relation("WrittenReviews")
  receivedReviews       Review[]            @relation("ReceivedReviews")
  uploadedAttachments   SessionAttachment[] @relation("UploadedSessionAttachments")
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  fullName       String
  major          String?
  bio            String?
  school         String   @default("New York University")
  graduationYear Int?
  avatarUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TutorProfile {
  id                 String               @id @default(cuid())
  userId             String               @unique
  headline           String?
  hourlyRateCents    Int?
  supportsOnline     Boolean              @default(true)
  supportsInPerson   Boolean              @default(false)
  defaultLocation    String?
  availabilityNotes  String?
  verificationStatus String               @default("UNVERIFIED")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects           TutorSubject[]
  applications       RequestApplication[]
}

model TuteeProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  learningGoals        String?
  preferredBudgetCents Int?
  supportsOnline       Boolean  @default(true)
  supportsInPerson     Boolean  @default(false)
  availabilityNotes    String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subject {
  id         String            @id @default(cuid())
  department String
  code       String
  name       String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  tutorLinks TutorSubject[]
  requests   TutoringRequest[]
  sessions   Session[]

  @@unique([department, code])
}

model TutorSubject {
  tutorProfileId  String
  subjectId       String
  proficiencyNote String?
  isPrimary       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  tutorProfile    TutorProfile @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)
  subject         Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([tutorProfileId, subjectId])
}

model TutoringRequest {
  id               String               @id @default(cuid())
  tuteeId          String
  subjectId        String
  title            String
  description      String
  budgetMinCents   Int?
  budgetMaxCents   Int?
  preferredMode    String
  locationText     String?
  preferredStartAt DateTime?
  preferredEndAt   DateTime?
  status           String               @default("OPEN")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  tutee            User                 @relation(fields: [tuteeId], references: [id], onDelete: Cascade)
  subject          Subject              @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  applications     RequestApplication[]
  messageThreads   MessageThread[]
  sessions         Session[]
}

model RequestApplication {
  id             String            @id @default(cuid())
  requestId      String
  tutorProfileId String
  message        String?
  status         String            @default("PENDING")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  request        TutoringRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  tutorProfile   TutorProfile      @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)

  @@unique([requestId, tutorProfileId])
}

model MessageThread {
  id              String           @id @default(cuid())
  tutorId         String
  tuteeId         String
  requestId       String?
  tutorLastReadAt DateTime?
  tuteeLastReadAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tutor           User             @relation("TutorThreads", fields: [tutorId], references: [id], onDelete: Cascade)
  tutee           User             @relation("TuteeThreads", fields: [tuteeId], references: [id], onDelete: Cascade)
  request         TutoringRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  messages        Message[]
  sessions        Session[]
}

model Message {
  id        String        @id @default(cuid())
  threadId  String
  senderId  String
  body      String
  createdAt DateTime      @default(now())
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Session {
  id                 String           @id @default(cuid())
  tutorId            String
  tuteeId            String
  subjectId          String
  threadId           String?
  requestId          String?
  scheduledAt        DateTime
  durationMinutes    Int
  mode               String
  locationText       String?
  agreedRateCents    Int?
  notes              String?
  status             String           @default("PENDING")
  proposedById       String
  cancelledById      String?
  cancelledAt        DateTime?
  cancellationReason String?
  roomToken          String           @unique @default(cuid())
  // recording + ai summary (opt-in by both sides)
  recordingConsentTutorAt DateTime?
  recordingConsentTuteeAt DateTime?
  recordingUrl       String?
  recordingStartedAt DateTime?
  recordingEndedAt   DateTime?
  // billing meter snapshots: minutes actually spent in the room
  meterMinutes       Int              @default(0)
  meterFinalisedAt   DateTime?
  // ai summary
  summary            String?
  summaryGeneratedAt DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tutor              User                @relation("TutorSessions", fields: [tutorId], references: [id], onDelete: Cascade)
  tutee              User                @relation("TuteeSessions", fields: [tuteeId], references: [id], onDelete: Cascade)
  subject            Subject             @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  thread             MessageThread?      @relation(fields: [threadId], references: [id], onDelete: SetNull)
  request            TutoringRequest?    @relation(fields: [requestId], references: [id], onDelete: SetNull)
  reviews            Review[]
  attachments        SessionAttachment[]
}

model SessionAttachment {
  id         String   @id @default(cuid())
  sessionId  String
  uploaderId String
  name       String
  mimeType   String
  sizeBytes  Int
  url        String
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  uploader   User     @relation("UploadedSessionAttachments", fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// per-session yjs op log used to relay live collab edits (code editor today,
// could also back the whiteboard later). each row is one Y.Doc update encoded
// as bytes; clients append theirs and poll for newer ones from peers.
model YjsOp {
  id        String   @id @default(cuid())
  sessionId String
  docKey    String
  payload   Bytes
  createdAt DateTime @default(now())

  @@index([sessionId, docKey, createdAt])
}

model Review {
  id                  String    @id @default(cuid())
  sessionId           String
  authorId            String
  revieweeId          String
  rating              Int
  comment             String?
  // sub-criteria 1..5; punctuality / preparation / communication apply to both sides;
  // helpfulness is tutee→tutor only and respectful is tutor→tutee only
  ratingPunctuality   Int?
  ratingPreparation   Int?
  ratingCommunication Int?
  ratingHelpfulness   Int?
  ratingRespectful    Int?
  // direction: TUTEE_TO_TUTOR or TUTOR_TO_TUTEE; computed from author role
  direction           String    @default("TUTEE_TO_TUTOR")
  // verified means the review came from a real completed session participant
  isVerified          Boolean   @default(true)
  // tutor / tutee may post one reply per review
  reply               String?
  replyAt             DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  session             Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  author              User      @relation("WrittenReviews", fields: [authorId], references: [id], onDelete: Cascade)
  reviewee            User      @relation("ReceivedReviews", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@unique([sessionId, authorId])
}
