# PostgreSQL (Neon, Supabase, Vercel Postgres, or local Docker)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth — use your production URL on Vercel, e.g. https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Optional: Vercel Blob (Storage → create store → env BLOB_READ_WRITE_TOKEN is injected when linked)
# Without this, avatar upload works only in local dev (writes to public/avatars).
# BLOB_READ_WRITE_TOKEN=""
